# - resource -------------------------------------------------------------------

<https://www.ceosys.de/fhir/ValueSet/vs-guideline-recommendation-status> a fhir:ValueSet;
  fhir:nodeRole fhir:treeRoot;
  fhir:Resource.id [ fhir:value "vs-guideline-recommendation-status"];
  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "extensions" ];
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><ul><li>Include these codes as defined in <a href=\"http://build.fhir.org/codesystem-cited-artifact-status-type.html\"><code>http://terminology.hl7.org/CodeSystem/cited-artifact-status-type</code></a><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"http://build.fhir.org/codesystem-cited-artifact-status-type.html#cited-artifact-status-type-withdrawn\">withdrawn</a></td><td>Withdrawn</td><td>The content that was not published has been removed from consideration for publishing by the submitter.</td></tr><tr><td><a href=\"http://build.fhir.org/codesystem-cited-artifact-status-type.html#cited-artifact-status-type-active\">active</a></td><td>Active</td><td>The content is considered complete for its current state by the content creator.</td></tr><tr><td><a href=\"http://build.fhir.org/codesystem-cited-artifact-status-type.html#cited-artifact-status-type-draft\">draft</a></td><td>Draft</td><td>The content is considered unfinished or incomplete and not representative of the current state desired by the content creator.</td></tr><tr><td><a href=\"http://build.fhir.org/codesystem-cited-artifact-status-type.html#cited-artifact-status-type-archived\">archived</a></td><td>Archived</td><td>The content is retired or considered no longer current but still available as part of the public record.</td></tr></table></li></ul></div>"
  ];
  fhir:ValueSet.url [ fhir:value "https://www.ceosys.de/fhir/ValueSet/vs-guideline-recommendation-status"];
  fhir:ValueSet.version [ fhir:value "0.2.0-snapshot"];
  fhir:ValueSet.name [ fhir:value "GuidelineRecommendationStatus"];
  fhir:ValueSet.title [ fhir:value "Guideline Recommendation Status"];
  fhir:ValueSet.status [ fhir:value "active"];
  fhir:ValueSet.date [ fhir:value "2022-06-09T15:00:21+00:00"^^xsd:dateTime];
  fhir:ValueSet.description [ fhir:value "Current status of a clinical practice guideline recommendation"];
  fhir:ValueSet.compose [
     fhir:ValueSet.compose.include [
       fhir:index 0;
       fhir:ValueSet.compose.include.system [ fhir:value "http://terminology.hl7.org/CodeSystem/cited-artifact-status-type" ];
       fhir:ValueSet.compose.include.concept [
         fhir:index 0;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "withdrawn" ];
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Withdrawn" ]
       ], [
         fhir:index 1;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "active" ];
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Active" ]
       ], [
         fhir:index 2;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "draft" ];
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Draft" ]
       ], [
         fhir:index 3;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "archived" ];
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Archived" ]
       ]
     ]
  ] .

