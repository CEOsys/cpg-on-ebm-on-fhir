       fhir:ContactPoint.value [ fhir:value "https://www.ceosys.de" ]
     ]
  ];
  fhir:ValueSet.description [ fhir:value "Degree of consensus reached"];
  fhir:ValueSet.compose [
     fhir:ValueSet.compose.include [
       fhir:index 0;
       fhir:ValueSet.compose.include.system [ fhir:value "http://terminology.hl7.org/CodeSystem/recommendation-strength" ];
       fhir:ValueSet.compose.include.concept [
