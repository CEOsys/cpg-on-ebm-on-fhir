# - resource -------------------------------------------------------------------

<https://www.ceosys.de/fhir/ValueSet/cochrane-pico> a fhir:ValueSet;
  fhir:nodeRole fhir:treeRoot;
  fhir:Resource.id [ fhir:value "cochrane-pico"];
  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ];
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><ul><li>Include all codes defined in <a href=\"CodeSystem-cochrane-pico-ontology.html\"><code>http://data.cochrane.org/ontologies/pico/</code></a></li></ul></div>"
  ];
  fhir:ValueSet.url [ fhir:value "https://www.ceosys.de/fhir/ValueSet/cochrane-pico"];
  fhir:ValueSet.version [ fhir:value "0.1.0"];
  fhir:ValueSet.name [ fhir:value "CochranePICO"];
  fhir:ValueSet.title [ fhir:value "Cochrane PICO"];
  fhir:ValueSet.status [ fhir:value "draft"];
  fhir:ValueSet.date [ fhir:value "2021-12-03"^^xsd:date];
  fhir:ValueSet.publisher [ fhir:value "CEOsys"];
  fhir:ValueSet.contact [
     fhir:index 0;
     fhir:ContactDetail.telecom [
       fhir:index 0;
       fhir:ContactPoint.system [ fhir:value "url" ];
       fhir:ContactPoint.value [ fhir:value "https://www.ceosys.de" ]
     ]
  ];
  fhir:ValueSet.description [ fhir:value "All codes from the Cochrane PICO ontology."];
  fhir:ValueSet.compose [
     fhir:ValueSet.compose.include [
       fhir:index 0;
       fhir:ValueSet.compose.include.system [ fhir:value "http://data.cochrane.org/ontologies/pico/" ]
     ]
  ] .

