# - resource -------------------------------------------------------------------

<https://www.ceosys.de/fhir/ValueSet/vs-rating-certainty-of-evidence> a fhir:ValueSet;
  fhir:nodeRole fhir:treeRoot;
  fhir:Resource.id [ fhir:value "vs-rating-certainty-of-evidence"];
  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "extensions" ];
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><ul><li>Include these codes as defined in <a href=\"http://build.fhir.org/codesystem-certainty-rating.html\"><code>http://terminology.hl7.org/CodeSystem/certainty-rating</code></a><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"http://build.fhir.org/codesystem-certainty-rating.html#certainty-rating-high\">high</a></td><td>High quality</td><td>High quality evidence.</td></tr><tr><td><a href=\"http://build.fhir.org/codesystem-certainty-rating.html#certainty-rating-moderate\">moderate</a></td><td>Moderate quality</td><td>Moderate quality evidence.</td></tr><tr><td><a href=\"http://build.fhir.org/codesystem-certainty-rating.html#certainty-rating-low\">low</a></td><td>Low quality</td><td>Low quality evidence.</td></tr><tr><td><a href=\"http://build.fhir.org/codesystem-certainty-rating.html#certainty-rating-very-low\">very-low</a></td><td>Very low quality</td><td>Very low quality evidence.</td></tr></table></li></ul></div>"
  ];
  fhir:ValueSet.url [ fhir:value "https://www.ceosys.de/fhir/ValueSet/vs-rating-certainty-of-evidence"];
  fhir:ValueSet.version [ fhir:value "0.1.0"];
  fhir:ValueSet.name [ fhir:value "RatingCertaintyofEvidence"];
  fhir:ValueSet.title [ fhir:value "Rating Certainty Of Evidence"];
  fhir:ValueSet.status [ fhir:value "draft"];
  fhir:ValueSet.date [ fhir:value "2022-01-31"^^xsd:date];
  fhir:ValueSet.publisher [ fhir:value "CEOsys"];
  fhir:ValueSet.contact [
     fhir:index 0;
     fhir:ContactDetail.telecom [
       fhir:index 0;
       fhir:ContactPoint.system [ fhir:value "url" ];
       fhir:ContactPoint.value [ fhir:value "https://www.ceosys.de" ]
     ]
  ];
  fhir:ValueSet.description [ fhir:value "Codes from EvidenceCertaintyRating related to certainty of evidence"];
  fhir:ValueSet.compose [
     fhir:ValueSet.compose.include [
       fhir:index 0;
       fhir:ValueSet.compose.include.system [ fhir:value "http://terminology.hl7.org/CodeSystem/certainty-rating" ];
       fhir:ValueSet.compose.include.concept [
         fhir:index 0;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "high" ];
         fhir:ValueSet.compose.include.concept.display [ fhir:value "High quality" ]
       ], [
         fhir:index 1;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "moderate" ];
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Moderate quality" ]
       ], [
         fhir:index 2;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "low" ];
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Low quality" ]
       ], [
         fhir:index 3;
         fhir:ValueSet.compose.include.concept.code [ fhir:value "very-low" ];
         fhir:ValueSet.compose.include.concept.display [ fhir:value "Very low quality" ]
       ]
     ]
  ] .

