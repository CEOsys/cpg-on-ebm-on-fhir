     fhir:PlanDefinition.goal.description [
       fhir:CodeableConcept.text [ fhir:value "The ventilator should be set up to provide a breath reate of at least 20 and at most per minute." ]
     ];
     fhir:PlanDefinition.goal.target [
       fhir:index 0;
       fhir:PlanDefinition.goal.target.measure [
         fhir:CodeableConcept.coding [
           fhir:index 0;
