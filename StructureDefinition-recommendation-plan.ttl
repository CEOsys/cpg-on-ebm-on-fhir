  fhir:snapshot [
     fhir:element ( [
       fhir:id [ fhir:v "PlanDefinition" ] ;
       fhir:path [ fhir:v "PlanDefinition" ] ;
       fhir:short [ fhir:v "The definition of a plan for a series of actions, independent of any specific patient or context" ] ;
       fhir:definition [ fhir:v "This resource allows for the definition of various types of plans as a sharable, consumable, and executable artifact. The resource is general enough to support the description of a broad range of clinical and non-clinical artifacts such as clinical decision support rules, order sets, protocols, and drug quality specifications." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:base [
         fhir:path [ fhir:v "PlanDefinition" ] ;
         fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
         fhir:max [ fhir:v "*" ]
       ] ;
       fhir:constraint ( [
         fhir:key [ fhir:v "cnl-0" ] ;
         fhir:severity [ fhir:v "warning" ] ;
         fhir:human [ fhir:v "Name should be usable as an identifier for the module by machine processing applications such as code generation" ] ;
         fhir:expression [ fhir:v "name.exists() implies name.matches('^[A-Z]([A-Za-z0-9_]){1,254}$')" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/PlanDefinition"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/PlanDefinition>
         ]
       ] [
         fhir:key [ fhir:v "pld-3" ] ;
         fhir:severity [ fhir:v "warning" ] ;
         fhir:human [ fhir:v "goalid should reference the id of a goal definition" ] ;
         fhir:expression [ fhir:v "%context.repeat(action).where((goalId in %context.goal.id).not()).exists().not()" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/PlanDefinition"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/PlanDefinition>
         ]
       ] [
         fhir:key [ fhir:v "pld-4" ] ;
         fhir:severity [ fhir:v "warning" ] ;
         fhir:human [ fhir:v "targetId should reference the id of an action" ] ;
         fhir:expression [ fhir:v "%context.repeat(action).relatedAction.where((targetId in %context.repeat(action).id).not()).exists().not()" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/PlanDefinition"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/PlanDefinition>
         ]
       ] [
         fhir:key [ fhir:v "selection-behavior-unique-or-no-value" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "If selectionBehavior is present, it must be the same for all actions in the group" ] ;
         fhir:expression [ fhir:v "action.selectionBehavior.distinct().count() <= 1" ] ;
         fhir:source [
           fhir:v "https://www.netzwerk-universitaetsmedizin.de/fhir/cpg-on-ebm-on-fhir/StructureDefinition/recommendation-plan"^^xsd:anyURI ;
           fhir:link <https://www.netzwerk-universitaetsmedizin.de/fhir/cpg-on-ebm-on-fhir/StructureDefinition/recommendation-plan>
         ]
       ] [
         fhir:key [ fhir:v "nested-action-requires-combination-method" ] ;
         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "If a nested action is present, a combination method must be present." ] ;
         fhir:expression [ fhir:v "action.exists() implies extension('https://www.netzwerk-universitaetsmedizin.de/fhir/cpg-on-ebm-on-fhir/StructureDefinition/ext-action-combination-method').exists()" ] ;
         fhir:source [
           fhir:v "https://www.netzwerk-universitaetsmedizin.de/fhir/cpg-on-ebm-on-fhir/StructureDefinition/recommendation-plan"^^xsd:anyURI ;
           fhir:link <https://www.netzwerk-universitaetsmedizin.de/fhir/cpg-on-ebm-on-fhir/StructureDefinition/recommendation-plan>
         ]
       ] ) ;
