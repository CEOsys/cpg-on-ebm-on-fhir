     fhir:Composition.section.focus [
       fhir:link <https://www.ceosys.de/fhir/PlanDefinition/COVID19VentilatedPatientsDexamethasoneApplicationPlan>;
       fhir:Reference.reference [ fhir:value "PlanDefinition/COVID19VentilatedPatientsDexamethasoneApplicationPlan" ]
     ];
     fhir:Composition.section.text [
       fhir:Narrative.status [ fhir:value "generated" ];
       fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><strong>Systemische Steroide:</strong> Bei Patienten mit COVID-19- und Sauerstoff-Bedarf (Niedrigfluss-Sauerstoff-Insufflation, High-Flow Nasal Cannula, Nichtinvasive Beatmung/CPAP, invasive Beatmung) soll eine Therapie mit systemischen Kortikosteroiden erfolgen. Die Therapie sollte mit 6 mg Dexamethason p.o. oder i.v. über zehn Tage erfolgen.</div>"
     ]
  ], [
     fhir:index 1;
     fhir:Composition.section.title [ fhir:value "Stationäre Therapie von COVID-19 Patienten" ];
     fhir:Composition.section.code [
       fhir:CodeableConcept.coding [
         fhir:index 0;
         fhir:Coding.system [ fhir:value "https://www.ceosys.de/fhir/CodeSystem/ceosys-code-system" ];
         fhir:Coding.code [ fhir:value "guideline-recommendation" ];
         fhir:Coding.display [ fhir:value "Clinical practice guideline recommendation" ]
       ]
     ];
     fhir:Composition.section.focus [
       fhir:link <https://www.ceosys.de/fhir/PlanDefinition/COVID19NonVentilatedPatientsDexamethasoneApplicationPlan>;
       fhir:Reference.reference [ fhir:value "PlanDefinition/COVID19NonVentilatedPatientsDexamethasoneApplicationPlan" ]
     ];
     fhir:Composition.section.text [
       fhir:Narrative.status [ fhir:value "generated" ];
       fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><strong>Systemische Steroide:</strong> Bei Patienten mit moderater Erkrankung (hospitalisiert ohne Notwendigkeit von Niedrigfluss-Sauerstoff-Insufflation) soll keine Therapie mit systemischen Kortikosteroiden erfolgen.</div>"
     ]
  ] .

