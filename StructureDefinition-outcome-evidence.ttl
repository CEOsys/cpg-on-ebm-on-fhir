       fhir:ElementDefinition.short [ fhir:value "Single evidence bit" ];
       fhir:ElementDefinition.definition [ fhir:value "The Evidence Resource provides a machine-interpretable expression of an evidence concept including the evidence variables (e.g., population, exposures/interventions, comparators, outcomes, measured variables, confounding variables), the statistics, and the certainty of this evidence." ];
